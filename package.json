    "eslint": "^9.39.4",
    "jsdom": "^27.0.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "serve": "^14.2.6",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  }
}
